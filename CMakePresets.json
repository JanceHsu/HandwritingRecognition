{
  "version": 5,
  "configurePresets": [
    {
      "name": "qtcreator-msvc2022-release",
      "displayName": "Qt Creator / MSVC 2022 / Release",
      "description": "Configure HandwritingRecognition for Qt Creator using the documented Qt 6.11.1 and LibTorch paths.",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/qtcreator-release",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "D:/Develop/Qt/6.11.1/msvc2022_64;D:/Develop/libtorch",
        "Torch_DIR": "D:/Develop/libtorch/share/cmake/Torch",
        "HANDWRITING_RECOG_DEFAULT_DEVICE": "auto"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qtcreator-msvc2022-release",
      "configurePreset": "qtcreator-msvc2022-release",
      "configuration": "Release"
    }
  ]
}